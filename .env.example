# ==============================================================================
# Enterprise Workforce Management - Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Database Connection (Prisma)
# Example: mongodb://username:password@localhost:27017/db_name?authSource=admin
# Or local connection: mongodb://localhost:27017/enterprise_workforce
DATABASE_URL="mongodb://localhost:27017/enterprise_workforce"

# Firebase Client SDK Configuration (Public variables prefix: NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-client-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-firebase-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-firebase-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-firebase-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"

# Firebase Admin SDK Configuration (Private variables)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com"
# Note: Escape private key newlines with '\n'
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR-PRIVATE-KEY-LINE-1\nYOUR-PRIVATE-KEY-LINE-2\n-----END PRIVATE KEY-----\n"

# Google Stitch SDK Configuration (Private variables)
# Get your API key from https://stitch.withgoogle.com
STITCH_API_KEY="your-stitch-api-key"
STITCH_PROJECT_ID="your-stitch-project-id"
